# Supabase — copy this file to `.env` and fill in your project's values.
# The VITE_* vars are inlined into the client bundle at build time, so they must
# be present in the build environment (locally in .env, and in the Cloudflare
# Pages "Environment variables" settings for production builds).
#
# These are the public/publishable (anon-level) keys — safe to ship to the browser.
# NEVER put the service_role key in any VITE_* var; it bypasses RLS.

SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# Server-only (NEVER expose to the client, no VITE_ prefix). Needed only if/when
# server functions use the admin client (client.server.ts) to bypass RLS.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
